# GitHub Linguist does not know Angl yet. Do not map `.angl` to a fake
# language like Markdown just to affect the language bar.
*.angl linguist-detectable=false

# Host/proof plumbing should not dominate the language bar.
app/** linguist-vendored
scripts/** linguist-vendored
tests/** linguist-vendored
Makefile linguist-vendored
docker-compose.yml linguist-vendored
